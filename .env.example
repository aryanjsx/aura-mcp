# Notion Integration API Key
# Create at: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx

# Notion Database ID
# Copy from the database URL: https://notion.so/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (optional — falls back to rule-based parser if missing)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Model (optional — defaults to gpt-3.5-turbo)
# OPENAI_MODEL=gpt-4o-mini

# GitHub Personal Access Token (optional — needed for github plugin)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM Mode (optional — "openai" or "local")
# AURA_LLM_MODE=openai
